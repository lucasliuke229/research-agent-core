# Research Agent Core — 环境变量配置模板
#
# 使用方法：
#   1. 复制此文件为 .env：  cp .env.example .env
#   2. 编辑 .env，填入你的 API Key 和模型信息
#   3. .env 文件不会被提交到 Git（已在 .gitignore 中）
#
# 支持任何兼容 OpenAI 接口格式的服务商：
#   - DeepSeek:    base_url=https://api.deepseek.com
#   - OpenAI:      base_url=https://api.openai.com/v1
#   - Groq:        base_url=https://api.groq.com/openai/v1
#   - 本地 Ollama: base_url=http://localhost:11434/v1
#   - 其他国产模型（智谱、通义、Moonshot 等）

# API 密钥（从服务商后台获取）
LLM_API_KEY=sk-your-api-key-here

# API 地址（DeepSeek 默认，换服务商只改这一行）
LLM_BASE_URL=https://api.deepseek.com

# 模型名称（DeepSeek 默认，换模型只改这一行）
LLM_MODEL=deepseek-chat
